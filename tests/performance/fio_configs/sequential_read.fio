; sequential_read.fio - Sequential read performance test
;
; Tests sequential read throughput with different block sizes

[global]
ioengine=sync
direct=1
time_based
runtime=30
group_reporting

[sequential-read-1m]
filename=large_100m.bin
rw=read
bs=1M
size=100M

[sequential-read-64k]
filename=large_100m.bin
rw=read
bs=64K
size=100M

[sequential-read-4k]
filename=large_100m.bin
rw=read
bs=4K
size=100M